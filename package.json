{
  "name": "blackwater",
  "version": "0.5.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.11.0",
  "engines": {
    "node": ">=24 <27"
  },
  "scripts": {
    "prepare": "husky",
    "dev": "concurrently -k -n server,web -c cyan,magenta \"pnpm dev:server\" \"pnpm dev:web\"",
    "dev:server": "tsx watch apps/server/src/index.ts",
    "predev:web": "pnpm pwa:build",
    "dev:web": "vite --config apps/web/vite.config.ts --host 0.0.0.0",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build": "pnpm typecheck && pnpm build:web && pnpm build:server",
    "build:web": "pnpm pwa:build && vite build --config apps/web/vite.config.ts",
    "build:server": "tsup apps/server/src/index.ts apps/server/src/healthcheck.ts apps/server/src/admin.ts --format esm --platform node --target node24 --out-dir dist/server --clean",
    "start": "node dist/server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run packages/game-core/test",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "playwright test",
    "test:balance": "tsx tools/balance/simulate.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "assets:render": "blender --background --factory-startup --python tools/blender/generate_assets.py -- --output assets/generated/raw --blend assets/source/blender/blackwater-kit.blend",
    "assets:build": "npm --prefix tools/assets run build",
    "assets:verify": "npm --prefix tools/assets run verify",
    "pwa:build": "node tools/pwa/build.mjs",
    "pwa:verify": "node tools/pwa/build.mjs --verify-only",
    "check": "pnpm format:check && pnpm typecheck && pnpm test && pnpm build && pnpm pwa:verify",
    "clean": "rimraf dist coverage test-results playwright-report"
  },
  "dependencies": {
    "@fastify/compress": "9.0.0",
    "@fastify/cookie": "^11.1.1",
    "@fastify/helmet": "^13.1.0",
    "@fastify/rate-limit": "11.1.0",
    "@fastify/static": "^9.3.0",
    "@fontsource/ibm-plex-mono": "5.2.7",
    "@fontsource/ibm-plex-sans": "5.2.8",
    "@fontsource/ibm-plex-sans-condensed": "5.2.8",
    "@zxing/browser": "0.1.5",
    "better-sqlite3": "^12.11.1",
    "fastify": "^5.10.0",
    "ipaddr.js": "2.4.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "1.61.1",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "24.13.3",
    "@types/qrcode": "1.5.6",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "concurrently": "9.2.1",
    "dependency-cruiser": "18.0.0",
    "esbuild": "0.28.1",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "fast-check": "4.9.0",
    "husky": "^9.1.7",
    "jsdom": "29.1.1",
    "prettier": "3.9.5",
    "rimraf": "6.1.3",
    "sharp": "0.35.3",
    "tsup": "8.5.0",
    "tsx": "4.23.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  }
}
